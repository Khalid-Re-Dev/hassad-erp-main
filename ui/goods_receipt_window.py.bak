                    # TODO: Populate table columns with actual data
                    self.table.setItem(row, 0, QTableWidgetItem(str(getattr(item, 'id', ''))))
                    self.table.setItem(row, 1, QTableWidgetItem(str(getattr(item, 'name', 'N/A'))))
                    
        except Exception as e:
